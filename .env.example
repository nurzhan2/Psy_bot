# Telegram
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# RAG settings
EMBEDDING_MODEL=text-embedding-3-small
TOP_K_PERSONAL=4
TOP_K_BOOKS=2

# Database
DB_PATH=data/bot.db

# Только если будет использоваться tools/fetch_channel_telethon.py
# (получить на https://my.telegram.org)
TG_API_ID=
TG_API_HASH=

# ============ Доработки (блоки 1–4) ============

# Блок 2: ключ шифрования переписки (32 байта base64).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Пусто = шифрование выключено (для теста ок, для продакшена задать обязательно).
FERNET_KEY=

# Блок 4: роутинг моделей и бюджет контекста
MODEL_SIMPLE=gpt-4o-mini
MODEL_COMPLEX=gpt-4o
CONTEXT_MAX_MESSAGES=16
CONTEXT_MAX_CHARS=12000
COMPLEXITY_CHAR_THRESHOLD=600

# Блок 1: ЮKassa и подписка. Пока ключи пустые — бот работает БЕЗ paywall.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
SUBSCRIPTION_PRICE_RUB=2990
SUBSCRIPTION_PERIOD_DAYS=30
SUBSCRIPTION_PLAN_NAME=Подписка на ИИ-ассистента
RENEWAL_NOTICE_DAYS=3
SUBSCRIPTION_RETURN_URL=https://t.me/EkaterinaZvezdinaBot
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/yookassa
SCHEDULER_INTERVAL_SECONDS=3600

# Блок 3: логирование
LOG_LEVEL=INFO
LOG_DIR=logs
SENTRY_DSN=
